{
  "expo": {
    "name": "AL BURHAN TOURS",
    "slug": "alburhan-travels-",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "alburhantours",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a00cc"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.alburhantours.app",
      "deploymentTarget": "15.1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "18"
    },
    "android": {
      "package": "com.alburhantours.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#1a00cc",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "versionCode": 7
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://al-burhan-tours-and-travels.replit.app/"
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1a00cc",
          "androidMode": "default",
          "androidCollapsedTitle": "Al Burhan Tours",
          "iosDisplayInForeground": true,
          "defaultChannel": "alburhan-push"
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/31cc1af8-5403-4f51-82a3-8730763a7dbc",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "31cc1af8-5403-4f51-82a3-8730763a7dbc"
      }
    }
  }
}
