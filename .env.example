# ============================================================
# Al Burhan Tours & Travels — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/alburhan_db

# Server
PORT=5000
NODE_ENV=production
SESSION_SECRET=your-long-random-secret-change-this-in-production

# CORS — comma-separated list of allowed origins
# Leave blank to allow all origins (dev only)
CORS_ORIGIN=https://alburhantravels.com,https://www.alburhantravels.com

# File uploads directory
# Defaults to ./uploads relative to working directory
UPLOADS_DIR=/var/www/alburhan/uploads

# Static files directory (built React frontend)
# Defaults to artifacts/alburhan/dist/public relative to api-server dist
STATIC_FILES_DIR=/var/www/alburhan/artifacts/alburhan/dist/public

# SMS notifications (Fast2SMS)
FAST2SMS_API_KEY=

# WhatsApp notifications (BotBee)
BOTBEE_API_KEY=
BOTBEE_BUSINESS_ID=
BOTBEE_PHONE_NUMBER_ID=

# Razorpay payments
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=

# Migration / admin operations key
MIGRATION_KEY=

# ============================================================
# Replit Object Storage (optional — Replit deployments only)
# Leave blank for VPS/Hostinger deployments; uploads fall back
# to disk storage (UPLOADS_DIR) automatically.
# These values are auto-provisioned by Replit's Object Storage tool.
# ============================================================
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=
